# Maintainer: MetroWind

pkgname=unspoken-git
pkgver=r67.gc905f92
pkgrel=1
pkgdesc='Micro-blog server that federates over ActivityPub'
arch=('x86_64')
url='https://github.com/MetroWind/unspoken'
license=('unknown')
depends=('curl' 'gcc-libs' 'glibc' 'openssl' 'sqlite')
makedepends=('cmake' 'git')
provides=('unspoken')
conflicts=('unspoken')
backup=('etc/unspoken/config.yaml')

source=(
    'unspoken::git+https://github.com/MetroWind/unspoken.git'
    'unspoken.service'
    'unspoken.sysusers'
    'unspoken.tmpfiles'
    'config.yaml'
)
sha256sums=(
    'SKIP'
    'c76cb2bef8a68ba70b00df359181160b35aef491d6186f4e6a01bd8e12fd3ace'
    '854a27c8fb3cc72d6cf541a654e4717339e8dab940b5b653df4c67e2908fd545'
    '13f941070585e369e52ad4344bf2e5bb02f58fa37ec7f229694f649137ae57df'
    'cefa05e4d0adaf96ce0eff40a716cb94f28f9a871f88b6785c2ba1656188018c'
)

pkgver()
{
    cd "$srcdir/unspoken"
    printf 'r%s.g%s' \
        "$(git rev-list --count HEAD)" \
        "$(git rev-parse --short=7 HEAD)"
}

build()
{
    cd "$srcdir"
    cmake -S unspoken -B build \
        -DCMAKE_BUILD_TYPE=None \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DUNSPOKEN_BUILD_TESTS=OFF \
        -Wno-dev
    cmake --build build
}

package()
{
    cd "$srcdir"
    install -Dm755 build/unspoken "$pkgdir/usr/bin/unspoken"

    install -d "$pkgdir/usr/share/unspoken"
    cp -a unspoken/templates "$pkgdir/usr/share/unspoken/"
    cp -a unspoken/static "$pkgdir/usr/share/unspoken/"

    install -Dm644 config.yaml "$pkgdir/etc/unspoken/config.yaml"
    install -Dm644 unspoken/docs/operator.md \
        "$pkgdir/usr/share/doc/unspoken/operator.md"
    install -Dm644 unspoken.service \
        "$pkgdir/usr/lib/systemd/system/unspoken.service"
    install -Dm644 unspoken.sysusers \
        "$pkgdir/usr/lib/sysusers.d/unspoken.conf"
    install -Dm644 unspoken.tmpfiles \
        "$pkgdir/usr/lib/tmpfiles.d/unspoken.conf"
}
